# Google OAuth (Sign in with Google) — get a Client ID from
# https://console.cloud.google.com/apis/credentials and add this dev URL
# (and your production domain) as an authorized JavaScript origin.
VITE_GOOGLE_CLIENT_ID=

# Analytics (both optional — leave blank to disable)
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=
# Meta (Facebook) Pixel ID
VITE_FB_PIXEL_ID=
