# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
# Get this from MongoDB Atlas (free tier) -> https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/marketplace?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin seed account (used only by utils/seed.js)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Google OAuth (Sign in with Google)
# Create a Client ID at https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 (and your production domain) as an authorized
# JavaScript origin. Only the Client ID is needed here — the server verifies
# the ID token Google sends to the client, no client secret required for this flow.
GOOGLE_CLIENT_ID=

# Email notifications (order confirmation, status updates)
# Any SMTP provider works — Gmail (with an App Password), Mailtrap for
# testing, SendGrid, etc. Leave SMTP_HOST blank to disable email sending
# entirely (the app will log instead of throwing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Aura Avenue <no-reply@auraavenue.com>"
